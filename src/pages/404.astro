---
import Base from "../layouts/Base.astro";
---
<Base title="404" description="Page not found.">
  <main class="wrap">
    <section class="block" style="border-top:none;text-align:center;padding:5rem 0">
      <div class="slab"><span class="pr">&#10140; ~</span> <span class="fn">cat 404.txt</span></div>
      <h1 class="g" style="font-size:clamp(3rem,12vw,7rem);font-weight:700;letter-spacing:-.04em;margin:.6rem 0">4<span class="acc">0</span>4</h1>
      <p class="muted mono">DETECT: no object found at this route.</p>
      <p style="margin-top:1.4rem"><a class="btn" href="/">&#10140; cd ~ (home)</a></p>
    </section>
  </main>
</Base>
